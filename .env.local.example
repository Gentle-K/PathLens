# Backend runtime
APP_ENV=development
SESSION_DB_PATH=./tmp/genius_actuary.db

# Set to `mock` for the easiest local boot. Switch to `openai_compatible`
# only when you want the optional LLM path.
ANALYSIS_ADAPTER=mock
ANALYSIS_PROVIDER=openai-compatible
ANALYSIS_REGION=global
ANALYSIS_API_BASE_URL=https://api.openai.com/v1
ANALYSIS_API_KEY=replace_me
ANALYSIS_MODEL=gpt-5.4-mini
ACTUARY_EXPERT_MODE=off
ACTUARY_STUDENT_MODEL_PATH=
ACTUARY_TEACHER_PROVIDER=openai
ACTUARY_DATA_REFRESH_PROFILE=monthly
ACTUARY_EVAL_SET_VERSION=v1

SEARCH_ADAPTER=mock
CHART_ADAPTER=structured
CALCULATION_MCP_ENABLED=true

# HashKey Chain defaults
HASHKEY_DEFAULT_EXECUTION_NETWORK=testnet
HASHKEY_INDEXER_FINALITY_BUFFER=2
HASHKEY_TESTNET_CHAIN_ID=133
HASHKEY_TESTNET_RPC_URL=https://testnet.hsk.xyz
HASHKEY_TESTNET_EXPLORER_URL=https://testnet-explorer.hsk.xyz
HASHKEY_TESTNET_PLAN_REGISTRY_ADDRESS=
HASHKEY_TESTNET_KYC_SBT_ADDRESS=
HASHKEY_TESTNET_ASSET_PROOF_REGISTRY_ADDRESS=

HASHKEY_MAINNET_CHAIN_ID=177
HASHKEY_MAINNET_RPC_URL=https://mainnet.hsk.xyz
HASHKEY_MAINNET_EXPLORER_URL=https://hashkey.blockscout.com
HASHKEY_MAINNET_PLAN_REGISTRY_ADDRESS=
HASHKEY_MAINNET_KYC_SBT_ADDRESS=
HASHKEY_MAINNET_ASSET_PROOF_REGISTRY_ADDRESS=

# Optional legacy fallbacks
PLAN_REGISTRY_ADDRESS=
KYC_SBT_ADDRESS=
ASSET_PROOF_REGISTRY_ADDRESS=

DEBUG_USERNAME=debug-admin
DEBUG_PASSWORD=change-me-debug-password

# Frontend runtime
VITE_API_MODE=rest
VITE_API_BASE_URL=
VITE_API_WITH_CREDENTIALS=true
VITE_API_TIMEOUT_MS=30000
VITE_PROXY_TARGET=http://127.0.0.1:8000
VITE_WS_PROXY_TARGET=ws://127.0.0.1:8000

# Wallet / deployer keys
PRIVATE_KEY=replace_me
PLAN_REGISTRY_DEPLOYER_PRIVATE_KEY=
ASSET_PROOF_REGISTRY_DEPLOYER_PRIVATE_KEY=
ASSET_PROOF_REGISTRY_INITIAL_ATTESTER=
HASHKEY_DEPLOY_NETWORK=testnet
