{
  "name": "genius-actuary",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "preview": "vite preview",
    "demo:video": "playwright test --config playwright.demo-video.config.ts e2e/specs/competition-demo-video.spec.ts && node ../scripts/collect_demo_videos.mjs",
    "demo:video:rest": "playwright test --config playwright.demo-video.config.ts e2e/specs/competition-rest-proof-video.spec.ts && node ../scripts/collect_demo_videos.mjs",
    "demo:video:all": "playwright test --config playwright.demo-video.config.ts e2e/specs/competition-demo-video.spec.ts e2e/specs/competition-rest-proof-video.spec.ts && node ../scripts/collect_demo_videos.mjs",
    "deploy:asset-proof-registry": "node ../scripts/deploy_asset_proof_registry.mjs",
    "deploy:plan-registry": "node ../scripts/deploy_plan_registry.mjs",
    "test": "vitest --maxWorkers=1",
    "test:unit": "vitest run --maxWorkers=1",
    "test:contracts": "vitest run src/contracts/*.contract.test.ts",
    "test:run": "vitest run --maxWorkers=1 --coverage",
    "test:json": "vitest run --maxWorkers=1 --coverage --reporter=default --reporter=json --outputFile=../test-results/frontend/vitest.json --coverage.reportsDirectory ../coverage/frontend",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@headlessui/react": "^2.2.9",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "formik": "^2.4.9",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.469.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "remark-gfm": "^4.0.1",
    "solc": "^0.8.34",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.47.11",
    "yup": "^1.7.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@ethereumjs/common": "^10.1.1",
    "@ethereumjs/tx": "^10.1.1",
    "@ethereumjs/util": "^10.1.1",
    "@ethereumjs/vm": "^10.1.1",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.1.11",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
